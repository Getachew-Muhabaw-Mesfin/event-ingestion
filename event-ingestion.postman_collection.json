{
  "info": {
    "name": "Event Ingestion Service",
    "description": "Tenant-aware event ingestion API tests. Includes happy path, tenant isolation, retry/failure simulation, and validation edge cases.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000/api/v1",
      "type": "string"
    },
    {
      "key": "validTenant",
      "value": "tenant-abc",
      "type": "string"
    },
    {
      "key": "anotherTenant",
      "value": "tenant-xyz",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Happy Path",
      "item": [
        {
          "name": "Basic user_action event",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 202 Accepted\", function () {",
                  "    pm.response.to.have.status(202);",
                  "});",
                  "",
                  "pm.test(\"Response has eventId and status pending\", function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('eventId');",
                  "    pm.expect(jsonData).to.have.property('status', 'pending');",
                  "    pm.expect(jsonData).to.have.property('message');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-tenant-id",
                "value": "{{validTenant}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"user_action\",\n  \"payload\": {\n    \"action\": \"clicked_button\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/events",
              "host": ["{{baseUrl}}"],
              "path": ["events"]
            },
            "description": "Valid event ingestion — should return 202 and an eventId"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Tenant Isolation",
      "item": [
        {
          "name": "Different tenant - isolated record",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 202\", function () {",
                  "    pm.response.to.have.status(202);",
                  "});",
                  "const jsonData = pm.response.json();",
                  "pm.environment.set(\"lastEventId\", jsonData.eventId);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-tenant-id",
                "value": "{{anotherTenant}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"user_action\",\n  \"payload\": {\n    \"action\": \"logged_in\",\n    \"userId\": \"u_999\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/events",
              "host": ["{{baseUrl}}"],
              "path": ["events"]
            },
            "description": "Creates an event under a different tenant — no cross-tenant bleed"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Retry & Failure Simulation",
      "item": [
        {
          "name": "Force failure (payload.fail = true) - tenant-abc",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 202 (accepted for async processing)\", function () {",
                  "    pm.response.to.have.status(202);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-tenant-id",
                "value": "{{validTenant}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"user_action\",\n  \"payload\": {\n    \"action\": \"will_fail\",\n    \"fail\": true\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/events",
              "host": ["{{baseUrl}}"],
              "path": ["events"]
            },
            "description": "Simulates a processing failure. Expect 3 attempts (with exponential backoff) then status = failed. Check logs for retry_attempt and processing_failed events."
          },
          "response": []
        },
        {
          "name": "Force failure - tenant-xyz",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 202\", function () {",
                  "    pm.response.to.have.status(202);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-tenant-id",
                "value": "{{anotherTenant}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"system_event\",\n  \"payload\": {\n    \"fail\": true,\n    \"reason\": \"downstream_unavailable\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/events",
              "host": ["{{baseUrl}}"],
              "path": ["events"]
            },
            "description": "Same failure simulation for a different tenant — isolation verified."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Rich Payload Variants",
      "item": [
        {
          "name": "Nested payload",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 202\", function () {",
                  "    pm.response.to.have.status(202);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-tenant-id",
                "value": "{{validTenant}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"user_action\",\n  \"payload\": {\n    \"action\": \"form_submitted\",\n    \"user\": {\n      \"id\": \"u_123\",\n      \"plan\": \"pro\"\n    },\n    \"form\": {\n      \"id\": \"onboarding\",\n      \"step\": 3\n    },\n    \"timestamp\": \"2024-01-15T10:00:00Z\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/events",
              "host": ["{{baseUrl}}"],
              "path": ["events"]
            },
            "description": "Payload is free‑form JSON — demonstrates flexible schema support."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Validation & Error Cases",
      "item": [
        {
          "name": "Missing x-tenant-id header",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 400 Bad Request\", function () {",
                  "    pm.response.to.have.status(400);",
                  "});",
                  "pm.test(\"Error message mentions tenant header\", function () {",
                  "    pm.expect(pm.response.text()).to.include(\"x-tenant-id\");",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"user_action\",\n  \"payload\": {}\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/events",
              "host": ["{{baseUrl}}"],
              "path": ["events"]
            }
          },
          "response": []
        },
        {
          "name": "Invalid body - type must be string",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 400 Bad Request\", function () {",
                  "    pm.response.to.have.status(400);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-tenant-id",
                "value": "{{validTenant}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": 12345,\n  \"payload\": {}\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/events",
              "host": ["{{baseUrl}}"],
              "path": ["events"]
            }
          },
          "response": []
        },
        {
          "name": "Missing required 'type' field",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 400\", function () {",
                  "    pm.response.to.have.status(400);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-tenant-id",
                "value": "{{validTenant}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"payload\": {\n    \"action\": \"no_type\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/events",
              "host": ["{{baseUrl}}"],
              "path": ["events"]
            }
          },
          "response": []
        }
      ]
    }
  ]
}
